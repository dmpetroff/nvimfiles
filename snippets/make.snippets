snippet cap Makefile caption section
	##############################
	# ${1:section}
	##############################
	# {{{
	$0
	# }}}

snippet cpp "C++ Makefile for 1.cpp in /tmp" b
	EXE := a.out
	SRC := ${1:1.cpp}
	CXXFLAGS := -O0 -g -Wall -std=c++20 -I$(HOME)/tools/cxx

	r: $(EXE)
		./$(EXE)

	$(EXE): $(SRC)
		$(CXX) $(CXXFLAGS) -o $@ $< -lfmt
